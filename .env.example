# Axodus Environment Variables

# API Configuration
VITE_PUBLIC_URL=http://localhost:5174

# Hummingbot API Configuration
VITE_API_URL=http://localhost:8000
VITE_API_USERNAME=admin
VITE_API_PASSWORD=admin

# MQTT Configuration (Real-time Updates)
VITE_MQTT_HOST=localhost
VITE_MQTT_PORT=8083
VITE_MQTT_USERNAME=admin
VITE_MQTT_PASSWORD=public

# Gateway Configuration (optional)
VITE_GATEWAY_URL=http://localhost:15888
VITE_GATEWAY_PASSPHRASE=

# WalletConnect Project ID (Web3 Wallets)
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Network Configuration
VITE_ENABLE_TESTNETS=false
