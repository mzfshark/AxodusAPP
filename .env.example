# Axodus Environment Variables

# API Configuration
VITE_PUBLIC_URL=http://localhost:5174
VITE_GOVERNANCE_API_URL=http://localhost:4002
VITE_MINING_API_URL=http://localhost:8787
VITE_ACS_API_URL=http://localhost:8788
VITE_BUSINESS_API_URL=http://localhost:8791

# WalletConnect Project ID (Web3 Wallets)
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Network Configuration
VITE_ENABLE_TESTNETS=false
VITE_GOVERNANCE_USE_MOCKS=true
VITE_MINING_USE_MOCKS=false
VITE_ACS_USE_MOCKS=false
VITE_BUSINESS_USE_API=false
